#!/usr/bin/env bash
# Audits subdomains for a given domain

# Function to audit a specific subdomain
# Arguments: $1 = domain, $2 = subdomain
audit_subdomain() {
  local domain=$1
  local subdomain=$2

  # shellcheck disable=SC2086
  dig "$subdomain.$domain" | awk -v sname="$subdomain" '
  BEGIN { found_answer = 0 }
  /;; ANSWER SECTION:/ { found_answer = 1; next }
  found_answer && $1 ~ "^" sname "\\." {
    if ($4 == "A" || $4 == "CNAME") {
      print "The subdomain " sname " is a " $4 " record and points to " $5
      found_answer = 0 # stop after first answer for this subdomain
    }
  }'
}

# Check if at least one argument (domain) is provided
if [ "$#" -lt 1 ]; then
  exit 1
fi

DOMAIN=$1
SUBDOMAIN=$2

if [ "$#" -eq 1 ]; then
  # List of subdomains to audit by default
  SUBDOMAINS=("www" "lb-01" "web-01" "web-02")
  for sub in "${SUBDOMAINS[@]}"; do
    audit_subdomain "$DOMAIN" "$sub"
  done
else
  # Audit the specific subdomain provided
  audit_subdomain "$DOMAIN" "$SUBDOMAIN"
fi
